# Canonical site origin used for metadata, sitemap.xml, robots.txt and OG URLs.
# In production set this in the Vercel project env (e.g. https://kuest.com).
# Falls back to VERCEL_PROJECT_PRODUCTION_URL on Vercel, then localhost in dev.
SITE_URL=

# Optional defaults shown in UI
NEXT_PUBLIC_GITHUB_APP_URL=https://github-app.kuest.com
NEXT_PUBLIC_DEFAULT_VERCEL_TEAM_ID=
NEXT_PUBLIC_DEFAULT_SUPABASE_REGION=us-east-1
NEXT_PUBLIC_SITE_NAME=Kuest
NEXT_PUBLIC_KUEST_CHAIN_MODE=amoy
NEXT_PUBLIC_REOWN_APPKIT_PROJECT_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000/launch
NEXT_PUBLIC_APP_ICON=http://localhost:3000/images/kuest-logo.svg

# Protocol pitch deck requests
RESEND_API_KEY=
RESEND_FROM_EMAIL="Kuest <hello@kuest.com>"
PROTOCOL_PITCH_DECK_TO_EMAIL=hello@kuest.com

# Vercel auth mode for Step 2:
# oauth (default) -> OAuth first, token fallback optional.
# token -> Access Token only.
NEXT_PUBLIC_VERCEL_AUTH_MODE=oauth
# true (default) keeps Access Token as alternative in UI when oauth mode is active.
NEXT_PUBLIC_VERCEL_ALLOW_TOKEN_FALLBACK=true

# Kuest API endpoints used for wallet-based key generation
CLOB_URL=https://clob.kuest.com
RELAYER_URL=https://relayer.kuest.com

# Optional: force default prefix used by Vercel Supabase integration metadata.
# Launchpad already retries common values automatically.
VERCEL_SUPABASE_PUBLIC_ENV_VAR_PREFIX=NEXT_PUBLIC_

# Required only when using OAuth mode for Vercel auth.
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# Optional (best effort): if set, launch also saves "Email (optional)"
# into the same Supabase table used by ../auth (key_emails).
# Missing/invalid values never block wallet sign or key generation.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional API rate limit tuning (per IP).
# Defaults are intentionally high to avoid blocking normal retries.
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_LAUNCH_MAX=30
RATE_LIMIT_SUPABASE_RESOURCES_MAX=240
RATE_LIMIT_DOMAIN_MAX=90
